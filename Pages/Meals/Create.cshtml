@page
@model MealPlanner.Pages.Meals.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Meal</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Meal.Name" class="control-label"></label>
                <input asp-for="Meal.Name" class="form-control" aria-required="true"/>
                <span asp-validation-for="Meal.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Meal.Category" class="control-label"></label>
                <input asp-for="Meal.Category" class="form-control" />
                <span asp-validation-for="Meal.Category" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Meal.Notes"></label>
                <input asp-for="Meal.Notes" class="form-control" />
                <span asp-validation-for="Meal.Notes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Meal.RecipeId" class="control-label">Recipe</label>
                <select asp-for="Meal.RecipeId" asp-items="Model.RecipeOptions" class="form-control">
                    <option value="">No recipe selected</option>
                </select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
